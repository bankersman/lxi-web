{
  "name": "@lxi-web/sim",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "TCP SCPI simulator framework and personality library used to validate the lxi-web stack without lab hardware.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./personalities": {
      "types": "./dist/personalities/index.d.ts",
      "import": "./dist/personalities/index.js"
    }
  },
  "bin": {
    "lxi-sim": "./bin/sim.mjs"
  },
  "files": [
    "dist",
    "bin",
    "bench.rigol.json",
    "personalities/**/*.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx/esm ./test/*.test.ts",
    "sim": "tsx src/cli.ts",
    "sim:rigol": "tsx src/cli.ts --config bench.rigol.json"
  },
  "devDependencies": {
    "@lxi-web/core": "workspace:*",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
