{
  "name": "lxi-web",
  "private": true,
  "version": "0.0.0",
  "description": "Browser dashboard for LXI / SCPI-over-TCP instruments",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r --filter \"@lxi-web/core\" build && pnpm -r --filter \"@lxi-web/server\" build && pnpm -r --filter \"@lxi-web/web\" build",
    "dev": "pnpm -r --parallel --filter \"@lxi-web/server\" --filter \"@lxi-web/web\" dev",
    "dev:server": "pnpm --filter @lxi-web/server dev",
    "dev:web": "pnpm --filter @lxi-web/web dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "sim": "pnpm --filter @lxi-web/sim sim",
    "sim:rigol": "pnpm --filter @lxi-web/sim sim:rigol",
    "test:sim": "pnpm --filter @lxi-web/sim test"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
